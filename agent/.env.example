# Copy this file to .env and fill in your key.
# The agent currently uses Groq (llama-3.3-70b-versatile) — see the active
# model line in agent.py.
# Get a free key at: https://console.groq.com
GROQ_API_KEY=your-key-here

# ── Want to switch providers? ─────────────────────────────────────────────
# Google Gemini (free tier) — https://aistudio.google.com/apikey
# GEMINI_API_KEY=...
#
# OpenAI (gpt-4o-mini, ~$0.001/plan) — https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
#
# Anthropic (claude-haiku, ~$0.002/plan) — https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...
#
# Then change the model in agent.py (see the comment at the top of that file).
