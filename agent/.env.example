# Copy this file to .env and fill in your key.
# The agent currently uses Google Gemini 2.0 Flash (free tier available).
# Get a key at: https://aistudio.google.com/apikey  (takes ~1 minute, no credit card)
GEMINI_API_KEY=your-key-here

# ── Want to switch providers? ─────────────────────────────────────────────
# OpenAI (gpt-4o-mini, ~$0.001/plan) — https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
#
# Anthropic (claude-haiku, ~$0.002/plan) — https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...
#
# Then change the model in agent.py (see the comment at the top of that file).
